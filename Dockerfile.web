# Multi-stage build for Level Bot Admin Panel Web UI

FROM node:20-alpine AS builder

WORKDIR /app

# Force NODE_ENV=development for build stage to ensure devDependencies are installed
ENV NODE_ENV=development

# Enable corepack for pnpm (comes with Node.js 16+)
RUN corepack enable && corepack prepare pnpm@10 --activate

# Copy monorepo files
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY .npmrc ./

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy source code
COPY packages/shared packages/shared/
COPY apps/web apps/web/
COPY tsconfig.json ./

# Build with turbo (handles dependencies automatically)
RUN pnpm build

# Production stage - use nginx to serve static SvelteKit output
FROM node:20-alpine

WORKDIR /app

# Enable corepack for pnpm (comes with Node.js 16+)
RUN corepack enable && corepack prepare pnpm@10 --activate

# Copy pnpm lock
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json .npmrc ./

# Install production dependencies for web app
RUN pnpm install --prod --frozen-lockfile

# Copy built app from builder
COPY --from=builder /app/apps/web/dist ./apps/web/dist
COPY --from=builder /app/packages/shared/dist ./packages/shared/dist
COPY --from=builder /app/node_modules ./node_modules

# Web runs on port 5173
EXPOSE 5173

# Serve the SvelteKit dist
WORKDIR /app/apps/web
CMD ["npm", "run", "preview"]
