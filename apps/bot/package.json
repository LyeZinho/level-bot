{
  "name": "@level-bot/bot",
  "version": "1.0.0",
  "description": "Level Bot - Discord bot with leveling, economy, and badges",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main",
    "dev": "nest start --watch",
    "debug": "nest start --debug --watch",
    "deploy": "tsx scripts/deploy-commands.ts",
    "seed": "tsx scripts/seed-shop.ts",
    "migrate": "node scripts/migrate-all.js",
    "migrate:all": "node scripts/migrate-all.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@level-bot/db": "workspace:*",
    "@level-bot/shared": "workspace:*",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-yet": "^5.1.5",
    "danbooru-sdk": "^1.0.0",
    "discord.js": "^14.14.1",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.2",
    "joi": "^18.1.1",
    "necord": "^6.12.4",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "sharp": "^0.32.1",
    "zlib-sync": "^0.1.9"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.3",
    "@nestjs/schematics": "^10.1.3",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.55.0",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^5.0.5",
    "rxjs": "^7.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
