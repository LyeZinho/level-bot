{
  "name": "level-bot-monorepo",
  "version": "1.0.0",
  "description": "Level Bot monorepo - Discord bot with admin panel",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "zlib-sync",
      "@swc/core",
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "lint": "turbo lint",
    "format": "turbo format",
    "type-check": "turbo type-check",
    "bot:build": "nest build",
    "bot:start": "node dist/main",
    "bot:dev": "nest start --watch",
    "bot:start:debug": "nest start --debug --watch",
    "deploy": "tsx scripts/deploy-commands.ts",
    "seed": "tsx scripts/seed-shop.ts",
    "migrate": "node scripts/migrate-all.js",
    "migrate:all": "node scripts/migrate-all.js",
    "migrate:boosts": "node scripts/legacy/migrate-boosts.js",
    "migrate:vips": "node scripts/legacy/migrate-vips.js",
    "migrate:badges": "node scripts/legacy/migrate-badges.js",
    "seed:badges": "node scripts/legacy/seed-badges.js",
    "migrate:hidden": "node scripts/legacy/migrate-hidden-items.js",
    "test:economy": "node scripts/legacy/test-economy.js",
    "fix:vip-tier": "node scripts/legacy/fix-vip-tier.js",
    "backup": "node scripts/backup-database.js backup",
    "backup:list": "node scripts/backup-database.js list",
    "backup:test": "node scripts/backup-database.js test",
    "restore": "node scripts/backup-database.js restore",
    "restore:latest": "node scripts/restore-latest-backup.js"
  },
  "keywords": [
    "discord",
    "bot",
    "levels",
    "ranking",
    "monorepo"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "bcryptjs": "^3.0.3",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-yet": "^5.1.5",
    "danbooru-sdk": "^1.0.0",
    "discord.js": "^14.14.1",
    "dotenv": "^16.3.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "joi": "^18.1.1",
    "necord": "^6.12.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.32.1",
    "vite": "^8.0.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.5.0",
    "@types/passport-jwt": "^4.0.1",
    "ts-loader": "^9.5.4",
    "tsx": "^4.21.0",
    "turbo": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
