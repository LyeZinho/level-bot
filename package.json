{
  "name": "level-bot",
  "version": "1.0.0",
  "description": "Bot Discord com sistema de níveis, ranking e perfis",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "dev": "npm run start:dev",
    "deploy": "node src/deploy-commands.js",
    "migrate": "node scripts/migrate-economy.js",
    "migrate:all": "node scripts/migrate-all.js",
    "migrate:boosts": "node scripts/migrate-boosts.js",
    "migrate:vips": "node scripts/migrate-vips.js",
    "migrate:badges": "node scripts/migrate-badges.js",
    "seed:badges": "node scripts/seed-badges.js",
    "migrate:hidden": "node scripts/migrate-hidden-items.js",
    "seed": "node scripts/seed-shop.js",
    "test:economy": "node scripts/test-economy.js",
    "fix:vip-tier": "node scripts/fix-vip-tier.js",
    "backup": "node scripts/backup-database.js backup",
    "backup:list": "node scripts/backup-database.js list",
    "backup:test": "node scripts/backup-database.js test",
    "restore": "node scripts/backup-database.js restore",
    "restore:latest": "node scripts/restore-latest-backup.js"
  },
  "keywords": [
    "discord",
    "bot",
    "levels",
    "ranking"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-yet": "^5.1.5",
    "danbooru-sdk": "^1.0.0",
    "discord.js": "^14.14.1",
    "dotenv": "^16.3.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "joi": "^18.1.1",
    "necord": "^6.12.4",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.32.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@types/node": "^25.5.0",
    "ts-loader": "^9.5.4",
    "typescript": "^6.0.2"
  }
}
